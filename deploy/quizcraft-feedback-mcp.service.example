[Unit]
Description=QuizCraft Feedback MCP service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/quizcraft-cn
EnvironmentFile=/etc/quizcraft-feedback-mcp.env
ExecStart=/opt/quizcraft-cn/.venv/bin/python /opt/quizcraft-cn/scripts/feedback_mcp_server.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
