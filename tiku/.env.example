# 增强版多API密钥LLM生成器环境变量配置示例
# 复制此文件为.env并填写实际的API密钥

# DeepSeek API密钥
API_KEY_1='{"key": "sk-your-deepseek-api-key-here", "base_url": "https://api.deepseek.com/v1", "model": "deepseek-chat", "weight": 1.0, "enabled": true, "provider": "deepseek"}'

# DeepSeek备用密钥
API_KEY_2='{"key": "sk-your-second-deepseek-api-key-here", "base_url": "https://api.deepseek.com/v1", "model": "deepseek-chat", "weight": 0.8, "enabled": true, "provider": "deepseek"}'

# OpenAI API密钥
API_KEY_3='{"key": "sk-your-openai-api-key-here", "base_url": "https://api.openai.com/v1", "model": "gpt-3.5-turbo", "weight": 0.9, "enabled": true, "provider": "openai"}'

# Anthropic API密钥
API_KEY_4='{"key": "sk-your-anthropic-api-key-here", "base_url": "https://api.anthropic.com/v1", "model": "claude-3-haiku-20240307", "weight": 0.7, "enabled": false, "provider": "anthropic"}'

# 其他配置
LLM_TIMEOUT=30
LLM_MAX_RETRIES=3
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=500

# 处理配置
BATCH_SIZE=10
MAX_WORKERS=5
ENABLE_CACHE=true
CACHE_TTL=86400

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./enhanced_llm_generator.log

# 安全配置（可选）
ENCRYPT_API_KEYS=false
KEY_ROTATION_INTERVAL=86400